# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=http://localhost:3000
# Public app URL used in transactional email links (password reset, login, receipts)
PUBLIC_APP_URL=http://localhost:3000

# ── Admin Authentication ──────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
ADMIN_SECRET=CHANGE_ME_BEFORE_DEPLOYING

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_MS=28800000
# Password reset token lifetime (in milliseconds). Default: 3600000 (1 hour)
PASSWORD_RESET_TTL_MS=3600000

# ── Rate limiting ─────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT=10

# ── Email (Brevo / Sendinblue SMTP) ──────────────────────────────────────────
# Set provider to "brevo" in the admin Settings → Integrations → Email panel.
# Brevo SMTP host and port are pre-filled as defaults (smtp-relay.brevo.com:587).
# Use your Brevo account login email as the username and an SMTP API key as the password.
# Generate an SMTP key at: https://app.brevo.com/settings/keys/smtp
#
# Example values (set via admin UI, not .env):
#   provider: brevo
#   host:     smtp-relay.brevo.com
#   port:     587
#   secure:   false
#   user:     your-brevo-account@email.com
#   pass:     <your Brevo SMTP API key>
#   from_name: RestOrder
#   from_email: noreply@yourdomain.com
