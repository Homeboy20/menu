# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=http://localhost:3000
# Public app URL used in transactional email links (password reset, login, receipts)
PUBLIC_APP_URL=http://localhost:3000

# ── Admin Authentication ──────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
ADMIN_SECRET=YOUR_ADMIN_SECRET

# Generate with: node -e "require('bcrypt').hash('yourPassword',12).then(h=>console.log(h))"
ADMIN_SECRET_HASH=YOUR_ADMIN_SECRET_HASH

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_MS=28800000
# Password reset token lifetime (in milliseconds). Default: 3600000 (1 hour)
PASSWORD_RESET_TTL_MS=3600000

# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
SESSION_SECRET=YOUR_SESSION_SECRET
CSRF_SECRET=YOUR_CSRF_SECRET
PHONE_HASH_SECRET=YOUR_PHONE_HASH_SECRET
ENABLE_DEV_ROUTES=false

# ── Rate limiting ─────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT=10
CONTACT_RATE_LIMIT=5

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/dbname
PG_POOL_MAX=20

# Production performance tuning
MENU_CACHE_MAX=500
MENU_CACHE_TTL_MS=300000
SCAN_DEDUPE_TTL_MS=300000
SCAN_DEDUPE_MAX=20000

# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
FIELD_ENCRYPTION_KEY=YOUR_FIELD_ENCRYPTION_KEY
